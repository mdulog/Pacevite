{
  "name": "Pacevite",
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.devcontainer.yml"],
  "service": "app",
  "runServices": ["db"],
  "workspaceFolder": "/workspaces/Pacevite",
  "remoteUser": "vscode",
  "shutdownAction": "stopCompose",
  "postCreateCommand": "dotnet restore Pacevite.slnx",
  "forwardPorts": [8080],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "eamodio.gitlens",
        "humao.rest-client"
      ]
    }
  }
}
